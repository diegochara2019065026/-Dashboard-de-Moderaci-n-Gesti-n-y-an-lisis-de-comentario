########################################################
# Aegis Filter – Variables de entorno (docker-compose)
# Copiar a ".env" y completar los valores reales.
# docker-compose.yml lee este archivo automáticamente.
########################################################

# ─── Base de datos MySQL ──────────────────────────────
DB_PASSWORD=AegisSecure2024!
DB_ROOT_PASSWORD=RootAegis2024!

# ─── Alexa Bridge ──────────────────────────────────────
# Skill ID de tu Alexa Skill (consola de Amazon Developer:
# Build > Endpoint, o el ARN/ID visible en la URL de la skill).
# Si se deja vacío, se omite la verificación de Skill ID.
ALEXA_SKILL_ID=

# Verificación de firma/certificado de Amazon.
# "true"  → producción (VPS, requiere HTTPS público).
# "false" → solo para pruebas locales sin HTTPS.
VERIFY_SIGNATURES=true

# ─── Caddy (Reverse Proxy / HTTPS) — solo VPS ─────────
# Solo se usa con: docker compose --profile proxy up -d
# Correo para el registro ACME de Let's Encrypt (avisos de renovación).
CADDY_ACME_EMAIL=tu-correo@ejemplo.com

# Puerto HTTP del host para el contenedor 'app' (Laravel).
# LOCAL: dejar en 80 (acceso directo en http://localhost).
# VPS:   cambiar a un puerto libre (ej. 8001), porque Caddy
#        pasará a ocupar los puertos 80 y 443 del host.
APP_HTTP_PORT=80

# Bind del alexa-bridge para depuración directa (sin pasar por Caddy/TLS).
# LOCAL: dejar en 8090.
# VPS:   usar "127.0.0.1:8090" para no exponerlo públicamente sin cifrar.
ALEXA_BRIDGE_BIND=8090
